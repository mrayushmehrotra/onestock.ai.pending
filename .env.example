# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/stockdb

# Redis
REDIS_URL=redis://localhost:6379

# Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Model
MODEL_PATH=model/saved/model.pkl
